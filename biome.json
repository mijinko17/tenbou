{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"files": {
		"ignore": [
			"**/.svelte-kit/**",
			"**/build/**",
			"**/dist/**",
			"**/.wrangler/**",
			"**/*.svelte",
			".claude/**",
			".devcontainer/**",
			".pnpm-store/**",
			".turbo/**",
			"pnpm-lock.yaml"
		]
	},
	"organizeImports": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	}
}
