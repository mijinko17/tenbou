{
  "name": "tenbou",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:22",

  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/node/.claude,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.ssh,target=/home/node/.ssh,type=bind,consistency=cached,readonly",
    "source=${localEnv:HOME}/.gitconfig,target=/home/node/.gitconfig,type=bind,consistency=cached,readonly"
  ],

  "remoteEnv": {
    "SSH_AUTH_SOCK": "${localEnv:SSH_AUTH_SOCK}"
  },

  "postCreateCommand": "sudo corepack enable && corepack prepare pnpm@latest --activate && pnpm install",

  "forwardPorts": [
    5173,
    8787
  ],
  "portsAttributes": {
    "5173": { "label": "SvelteKit" },
    "8787": { "label": "Wrangler (Workers)" }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "svelte.svelte-vscode",
        "biomejs.biome",
        "bradlc.vscode-tailwindcss",
        "usernamehw.errorlens",
        "ms-vscode.vscode-typescript-next",
        "anthropic.claude-code"
      ],
      "settings": {
        "editor.defaultFormatter": "biomejs.biome",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "quickfix.biome": "explicit"
        },
        "[svelte]": {
          "editor.defaultFormatter": "svelte.svelte-vscode"
        },
        "typescript.tsdk": "node_modules/typescript/lib"
      }
    }
  }
}
